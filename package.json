{
  "name": "ecg-analyzer-mlp",
  "version": "1.0.0",
  "description": "Medical-grade ECG Analyzer with MLP Algorithm",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:web": "vite",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run server\" \"npm run shap\"",
    "server": "node server/denoise-server.js",
    "shap": "python server/shap_server.py",
    "build": "npm run prepare-data && tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "prepare-data": "node scripts/prepare-ecg-data.js",
    "optimize-data": "node scripts/optimize-ecg-data.js",
    "process-all": "npm run optimize-data && npm run prepare-data",
    "denoise": "python scripts/denoise_ptbxl_data.py"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.17.0",
    "chart.js": "^4.4.1",
    "clsx": "^2.1.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "framer-motion": "^11.0.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "tailwindcss": "^3.4.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.33",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
